# =============================================================================
# Confluent Cloud Gateway Demo - Environment Configuration (Azure)
# =============================================================================
# Copy this file to .env and fill in your actual values
#   cp .env.example .env
#   # Edit .env with your configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Azure Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Azure subscription ID (get it from: az account show --query id -o tsv)
AZURE_SUBSCRIPTION_ID=YOUR_AZURE_SUBSCRIPTION_ID

# Owner email address (required by Azure Policy for resource tagging)
OWNER_EMAIL=your.email@company.com

# Azure region for AKS cluster deployment
# Use lowercase, no spaces (e.g., centralus, eastus, westus2, northeurope, westeurope)
# NOTE: Use a different region than the Confluent Cloud clusters
AZURE_LOCATION=centralus

# Azure resource group name
RESOURCE_GROUP_NAME=cc-gateway-rg

# Name for your AKS cluster
AKS_CLUSTER_NAME=cc-gateway-aks

# -----------------------------------------------------------------------------
# Confluent Cloud Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get your API credentials from https://confluent.cloud/settings/api-keys
# Use Cloud API keys (not cluster-specific keys)
CONFLUENT_CLOUD_API_KEY=YOUR_CONFLUENT_CLOUD_API_KEY
CONFLUENT_CLOUD_API_SECRET=YOUR_CONFLUENT_CLOUD_API_SECRET

# -----------------------------------------------------------------------------
# Gateway Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Azure Private DNS Zone name (default: axa.com)
DNS_ZONE_NAME=axa.com

# Gateway DNS record name (kafka.cc for kafka.cc.axa.com)
GATEWAY_DNS_RECORD_NAME=kafka.cc

# Full gateway domain name (will be DNS_RECORD_NAME.DNS_ZONE_NAME)
GATEWAY_DOMAIN=kafka.cc.axa.com

# -----------------------------------------------------------------------------
# AKS Cluster Configuration (OPTIONAL)
# -----------------------------------------------------------------------------
# Kubernetes version for AKS cluster (default: 1.36)
KUBERNETES_VERSION=1.36

# Azure VM size for AKS worker nodes (default: Standard_D2s_v3)
# Options: Standard_D2s_v3, Standard_D4s_v3, Standard_D8s_v3, etc.
VM_SIZE=Standard_D2s_v3

# Availability zones for node pool (comma-separated, default: 1,2)
AVAILABILITY_ZONES=1,2

# -----------------------------------------------------------------------------
# Confluent Cloud Kafka Clusters (OPTIONAL)
# -----------------------------------------------------------------------------
# Confluent Cloud environment name (default: cc-gateway-demo-azure)
CONFLUENT_ENVIRONMENT_NAME=cc-gateway-demo-azure

# Primary Azure Kafka cluster configuration
# Region: eastus (East US) - Azure region for primary cluster
PRIMARY_CLUSTER_NAME=azure-eastus-primary
PRIMARY_CLUSTER_REGION=eastus

# DR Azure Kafka cluster configuration
# Region: westus2 (West US 2) - Azure region for DR cluster
DR_CLUSTER_NAME=azure-westus2-dr
DR_CLUSTER_REGION=westus2

# Kafka cluster availability configuration (default: SINGLE_ZONE)
# Options: SINGLE_ZONE (cheaper) or MULTI_ZONE (higher availability)
KAFKA_AVAILABILITY=SINGLE_ZONE

# -----------------------------------------------------------------------------
# Certificate Configuration (OPTIONAL)
# -----------------------------------------------------------------------------
# These are used for generating TLS certificates
# JKS keystore/truststore password (default: confluent)
JKS_PASSWORD=confluent

# Client truststore password (default: clienttrustpass)
CLIENT_TRUSTSTORE_PASSWORD=clienttrustpass

# Certificate details for gateway TLS certificate
CERT_COUNTRY=US
CERT_STATE=CA
CERT_CITY=Mountain View
CERT_ORG=Confluent
CERT_OU=Engineering

# -----------------------------------------------------------------------------
# Auto-populated Variables (DO NOT EDIT)
# -----------------------------------------------------------------------------
# These variables are automatically populated by the deploy.sh script
# after Terraform creates the Confluent Cloud clusters
# PRIMARY_CLUSTER_ENDPOINT=
# DR_CLUSTER_ENDPOINT=
# PRIMARY_CLUSTER_API_KEY=
# PRIMARY_CLUSTER_API_SECRET=
# DR_CLUSTER_API_KEY=
# DR_CLUSTER_API_SECRET=
# PRIMARY_SERVICE_ACCOUNT_ID=
# DR_SERVICE_ACCOUNT_ID=
# CC_SCHEMA_REGISTRY_ENDPOINT=
# CC_SCHEMA_REGISTRY_API_KEY=
# CC_SCHEMA_REGISTRY_API_SECRET=
