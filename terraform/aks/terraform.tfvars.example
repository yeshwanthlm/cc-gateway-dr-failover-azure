# Azure AKS Cluster Configuration
# Copy this file to terraform.tfvars and customize as needed
# Or use the deploy.sh script which will auto-generate this from .env

azure_subscription_id   = "YOUR_AZURE_SUBSCRIPTION_ID"
azure_location          = "centralus"
resource_group_name     = "cc-gateway-rg"
cluster_name            = "cc-gateway-aks"
kubernetes_version      = "1.29"
vm_size                 = "Standard_D2s_v3"
availability_zones      = ["1", "2"]

# Azure Private DNS Configuration
dns_zone_name           = "axa.com"
gateway_dns_record_name = "kafka.cc"
gateway_lb_hostname     = ""  # Will be updated after LoadBalancer is created
